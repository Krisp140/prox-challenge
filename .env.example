ANTHROPIC_API_KEY=your-api-key-here

# Optional: enables the Nano Banana image pass (SVG → polished image via Replicate).
# Reference images from the manual are auto-matched and sent to guide the generation.
REPLICATE_API_TOKEN=your-replicate-token-here
# Override the default model (black-forest-labs/flux-2-pro):
# IMAGE_MODEL=black-forest-labs/flux-schnell

# Google OAuth (optional — enables sign-in and chat history persistence)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
AUTH_SECRET=generate-with-npx-auth-secret

# Vercel Postgres (required for chat history)
POSTGRES_URL=your-postgres-connection-string
